# Finance Tracker — Backend env (NestJS)
# Copie ce fichier en .env et remplis les valeurs.

# Port d'écoute
PORT=3000

# Mode (production | development)
NODE_ENV=production

# PIN de protection (4-8 chiffres, gardé en sessionStorage côté frontend)
APP_PIN=0000

# Origine autorisée pour le CORS (URL du frontend)
CORS_ORIGIN=http://localhost:4200

# Clé API Anthropic — nécessaire pour l'analyse PDF Claude
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Dossier des données (montés en volume Docker)
DATA_DIR=/app/data
UPLOAD_DIR=/app/data/uploads

# Taille max d'un PDF de relevé (Mo)
MAX_FILE_SIZE_MB=20
